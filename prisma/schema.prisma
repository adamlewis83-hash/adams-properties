generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Property {
  id              String   @id @default(cuid())
  name            String
  address         String?
  city            String?  @default("Forest Grove")
  state           String?  @default("OR")
  zip             String?
  purchasePrice   Decimal? @db.Decimal(12, 2)
  purchaseDate    DateTime? @db.Date
  currentValue    Decimal? @db.Decimal(12, 2)
  downPayment     Decimal? @db.Decimal(12, 2)
  closingCosts    Decimal? @db.Decimal(12, 2)
  rehabCosts      Decimal? @db.Decimal(12, 2)
  ownershipPercent Decimal @default(1) @db.Decimal(5, 4)
  notes           String?
  units           Unit[]
  loans           Loan[]
  expenses        Expense[]
  distributions   Distribution[]
  vendors         Vendor[]
  members         PropertyMember[]
  documents       Document[]
  recurring       RecurringExpense[]
  capex           CapitalImprovement[]
  audits          AuditEvent[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Application-level user record. Linked 1:1 to a Supabase auth.users row
// via authUserId. Holds role + per-property memberships.
model AppUser {
  id           String           @id @default(cuid())
  authUserId   String           @unique
  email        String           @unique
  firstName    String?
  lastName     String?
  role         String           @default("partner") // "admin" | "partner" | "manager"
  memberships  PropertyMember[]
  invitesSent  PartnerInvite[]  @relation("inviter")
  documents    Document[]
  audits       AuditEvent[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model PropertyMember {
  id               String   @id @default(cuid())
  userId           String
  propertyId       String
  permissions      String   @default("read") // "read" | "manage"
  // Equity share for owner statements (0..1, e.g. 0.5 = 50%). Zero for
  // managers who don't share in cash flow.
  ownershipPercent Decimal  @default(0) @db.Decimal(5, 4)
  user             AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  property         Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())

  @@unique([userId, propertyId])
  @@index([propertyId])
}

model CapitalImprovement {
  id              String   @id @default(cuid())
  propertyId      String
  unitId          String?
  category        String   // "Roof" | "HVAC" | "Appliances" | "Plumbing" | "Electrical" | "Flooring" | "Renovation" | "Other"
  description     String
  amount          Decimal  @db.Decimal(12, 2)
  placedInService DateTime @db.Date
  // IRS class life — most residential cap-ex is 27.5y for the structure;
  // appliances/carpet 5y; HVAC inside the building 27.5y per IRS for
  // residential rental; site improvements 15y. Editable per item.
  usefulLifeYears Int      @default(27)
  vendor          String?
  notes           String?
  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([propertyId])
}

model AuditEvent {
  id          String   @id @default(cuid())
  // Who did it.
  userId      String?
  userEmail   String?
  // What happened: 'lease.create', 'expense.update', 'unit.delete',
  // 'document.upload', 'plaid.connect', 'role.change', etc.
  action      String
  // Optional scope — used by the activity feed to filter to one
  // property's events.
  propertyId  String?
  // Free-form target reference (e.g., 'lease/abc123', 'unit/xyz').
  entityType  String?
  entityId    String?
  // Human-readable summary shown in the feed.
  summary     String
  // Optional structured diff/details for forensics.
  details     Json?
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())

  user        AppUser? @relation(fields: [userId], references: [id], onDelete: SetNull)
  property    Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([propertyId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model BankLink {
  id              String            @id @default(cuid())
  itemId          String            @unique
  accessToken     String
  institutionId   String?
  institutionName String?
  cursor          String?
  status          String            @default("active") // "active" | "needs_relink" | "removed"
  lastSyncAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  accounts        BankAccount[]
  transactions    BankTransaction[]
}

model BankAccount {
  id             String            @id @default(cuid())
  bankLinkId     String
  plaidAccountId String            @unique
  name           String?
  officialName   String?
  mask           String?
  type           String?
  subtype        String?
  bankLink       BankLink          @relation(fields: [bankLinkId], references: [id], onDelete: Cascade)
  transactions   BankTransaction[]

  @@index([bankLinkId])
}

model BankTransaction {
  id               String       @id @default(cuid())
  bankLinkId       String
  bankAccountId    String?
  plaidTxId        String       @unique
  date             DateTime     @db.Date
  // Plaid convention: positive = outflow (expense), negative = inflow (deposit/payment).
  amount           Decimal      @db.Decimal(14, 2)
  name             String
  merchant         String?
  plaidCategory    String?
  pending          Boolean      @default(false)
  // Domain mapping.
  status           String       @default("unmapped") // "unmapped" | "expense" | "payment" | "ignored"
  mappedExpenseId  String?      @unique
  mappedPropertyId String?
  notes            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  bankLink         BankLink     @relation(fields: [bankLinkId], references: [id], onDelete: Cascade)
  bankAccount      BankAccount? @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)

  @@index([bankLinkId, date])
  @@index([status])
}

model RecurringExpense {
  id          String    @id @default(cuid())
  propertyId  String
  category    String
  amount      Decimal   @db.Decimal(12, 2)
  vendor      String?
  memo        String?
  // Day-of-month to apply (1-28 to avoid Feb edge cases).
  dayOfMonth  Int       @default(1)
  startDate   DateTime  @db.Date
  endDate     DateTime? @db.Date
  active      Boolean   @default(true)
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([propertyId])
}

model Document {
  id           String    @id @default(cuid())
  // Exactly one of these is set, depending on what the doc is attached to.
  propertyId   String?
  unitId       String?
  leaseId      String?
  name         String
  category     String    @default("Other") // "Lease" | "Insurance" | "Inspection" | "Photo" | "Receipt" | "Tax" | "Other"
  storagePath  String    // path inside the "documents" Supabase Storage bucket
  contentType  String?
  sizeBytes    Int?
  notes        String?
  uploadedById String?
  uploadedAt   DateTime  @default(now())

  property     Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit         Unit?     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  lease        Lease?    @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  uploadedBy   AppUser?  @relation(fields: [uploadedById], references: [id])

  @@index([propertyId])
  @@index([unitId])
  @@index([leaseId])
}

model PartnerInvite {
  id           String    @id @default(cuid())
  email        String
  inviterId    String
  propertyId   String?   // optional — auto-add member to this property on accept
  permissions  String    @default("read")
  role         String    @default("partner")
  token        String    @unique @default(cuid())
  createdAt    DateTime  @default(now())
  expiresAt    DateTime
  acceptedAt   DateTime?
  inviter      AppUser   @relation("inviter", fields: [inviterId], references: [id])

  @@index([email])
}

model Asset {
  id              String    @id @default(cuid())
  symbol          String
  name            String?
  kind            String    // "Stock", "Crypto", "Cash", "Retirement", "Fund", "Other"
  account         String?   // "Chase Brokerage", "401k", "Wallet", etc.
  quantity        Decimal   @db.Decimal(24, 8)
  costBasis       Decimal?  @db.Decimal(14, 2)  // total cost basis in USD
  avgCostPerShare Decimal?  @db.Decimal(14, 4)
  acquisitionDate DateTime? @db.Date
  manualPrice     Decimal?  @db.Decimal(14, 4)  // used if no live price source
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Distribution {
  id          String   @id @default(cuid())
  propertyId  String
  paidAt      DateTime @db.Date
  amount      Decimal  @db.Decimal(12, 2)
  kind        String   @default("Distribution") // "Distribution", "Refi Cash Out", "Sale Proceeds"
  memo        String?
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([propertyId, paidAt])
}

model Loan {
  id              String   @id @default(cuid())
  propertyId      String
  lender          String
  originalAmount  Decimal  @db.Decimal(12, 2)
  currentBalance  Decimal  @db.Decimal(12, 2)
  interestRate    Decimal  @db.Decimal(5, 3)
  termMonths      Int
  monthlyPayment  Decimal  @db.Decimal(10, 2)
  startDate       DateTime @db.Date
  maturityDate    DateTime? @db.Date
  loanType        String?  @default("Fixed")
  notes           String?
  property        Property @relation(fields: [propertyId], references: [id])
  payments        LoanPayment[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([propertyId])
}

model LoanPayment {
  id            String   @id @default(cuid())
  loanId        String
  paidAt        DateTime @db.Date
  totalAmount   Decimal  @db.Decimal(10, 2)
  principal     Decimal  @db.Decimal(10, 2)
  interest      Decimal  @db.Decimal(10, 2)
  escrow        Decimal? @db.Decimal(10, 2)
  memo          String?
  loan          Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@index([loanId, paidAt])
}

model Unit {
  id         String   @id @default(cuid())
  propertyId String?
  label      String   @unique
  bedrooms   Int
  bathrooms  Float
  sqft       Int?
  rent       Decimal  @db.Decimal(10, 2)
  rubs       Decimal  @default(0) @db.Decimal(10, 2)
  parking    Decimal  @default(0) @db.Decimal(10, 2)
  storage    Decimal  @default(0) @db.Decimal(10, 2)
  notes      String?
  property   Property? @relation(fields: [propertyId], references: [id])
  leases     Lease[]
  tickets    MaintenanceTicket[]
  documents  Document[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([propertyId])
}

model Tenant {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String?  @unique
  phone     String?
  notes     String?
  leases    Lease[]
  vehicles  TenantVehicle[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TenantVehicle {
  id           String   @id @default(cuid())
  tenantId     String
  year         Int?
  make         String
  model        String
  color        String?
  licensePlate String
  state        String?  @default("OR")
  notes        String?
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId])
}

model Lease {
  id              String      @id @default(cuid())
  unitId          String
  tenantId        String
  startDate       DateTime    @db.Date
  endDate         DateTime    @db.Date
  monthlyRent     Decimal     @db.Decimal(10, 2)
  securityDeposit Decimal     @default(0) @db.Decimal(10, 2)
  status          LeaseStatus @default(ACTIVE)
  portalToken     String?     @unique @default(cuid())
  signToken       String?     @unique @default(cuid())
  documentUrl     String?
  // Lease-form fields (Oregon residential lease).
  utilitiesLandlord String?
  utilitiesTenant   String?
  smokingPolicy     String?    @default("PROHIBITED") // PROHIBITED | OUTDOORS_ONLY | UNRESTRICTED
  petPolicy         String?    @default("NONE")       // NONE | ALLOWED
  petDeposit        Decimal?   @db.Decimal(10, 2)
  petConditions     String?
  leadPaintBuiltBefore1978 Boolean? @default(false)
  inFloodZone       Boolean?   @default(false)
  pendingLegalActions Boolean? @default(false)
  additionalTerms   String?
  landlordName      String?    @default("Adam's Properties")
  signingLinkSentAt    DateTime?
  signingLinkSentTo    String?
  unit            Unit        @relation(fields: [unitId], references: [id])
  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  charges         Charge[]
  payments        Payment[]
  documents       Document[]
  signatures      LeaseSignature[]
  inspections     LeaseInspection[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([unitId])
  @@index([tenantId])
}

model LeaseInspection {
  id            String   @id @default(cuid())
  leaseId       String
  type          String   // "MOVE_IN" | "MOVE_OUT"
  inspectedAt   DateTime @db.Date
  inspectorName String?
  tenantPresent Boolean  @default(true)
  generalNotes  String?
  // Audit + signing
  inspectorSig  String?
  inspectorSigAt DateTime?
  tenantSig     String?
  tenantSigAt   DateTime?
  signToken     String?  @unique @default(cuid())
  ipAddress     String?
  userAgent     String?
  signingLinkSentAt DateTime?
  signingLinkSentTo String?
  lease         Lease    @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  items         LeaseInspectionItem[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([leaseId])
}

model LeaseInspectionItem {
  id            String   @id @default(cuid())
  inspectionId  String
  room          String   // e.g. "Living Room", "Kitchen", "Bedroom 1"
  category      String   // e.g. "Floors", "Walls", "Appliances"
  condition     String   // EXCELLENT | GOOD | FAIR | POOR | DAMAGED | NA
  notes         String?
  photoUrl      String?
  sortOrder     Int      @default(0)
  inspection    LeaseInspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([inspectionId])
}

model LeaseSignature {
  id            String   @id @default(cuid())
  leaseId       String
  role          String   // "TENANT" | "LANDLORD"
  signerName    String
  typedSignature String
  ipAddress     String?
  userAgent     String?
  signedAt      DateTime @default(now())
  lease         Lease    @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@index([leaseId])
}

enum LeaseStatus {
  PENDING
  ACTIVE
  ENDED
  TERMINATED
}

model Charge {
  id        String     @id @default(cuid())
  leaseId   String
  type      ChargeType @default(RENT)
  amount    Decimal    @db.Decimal(10, 2)
  dueDate   DateTime   @db.Date
  memo      String?
  lease     Lease      @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@index([leaseId, dueDate])
}

enum ChargeType {
  RENT
  LATE_FEE
  UTILITY
  OTHER
}

model Payment {
  id        String        @id @default(cuid())
  leaseId   String
  amount    Decimal       @db.Decimal(10, 2)
  paidAt    DateTime      @db.Date
  method    PaymentMethod @default(ACH)
  reference String?
  memo      String?
  lease     Lease         @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@index([leaseId, paidAt])
}

enum PaymentMethod {
  ACH
  CARD
  CHECK
  CASH
  OTHER
}

model Vendor {
  id        String              @id @default(cuid())
  name      String
  trade     String?
  phone     String?
  email     String?
  notes     String?
  tickets   MaintenanceTicket[]
  properties Property[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
}

model MaintenanceTicket {
  id          String       @id @default(cuid())
  unitId      String?
  vendorId    String?
  title       String
  description String?
  status      TicketStatus @default(OPEN)
  priority    Priority     @default(NORMAL)
  cost        Decimal?     @db.Decimal(10, 2)
  openedAt    DateTime     @default(now())
  closedAt    DateTime?
  unit        Unit?        @relation(fields: [unitId], references: [id])
  vendor      Vendor?      @relation(fields: [vendorId], references: [id])

  @@index([status])
  @@index([unitId])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_VENDOR
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model Expense {
  id         String    @id @default(cuid())
  propertyId String?
  unitId     String?
  category   String
  amount     Decimal   @db.Decimal(10, 2)
  incurredAt DateTime  @db.Date
  vendor     String?
  memo       String?
  receiptUrl String?
  property   Property? @relation(fields: [propertyId], references: [id])
  createdAt  DateTime  @default(now())

  @@index([incurredAt])
  @@index([propertyId])
}
