generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Property {
  id              String   @id @default(cuid())
  name            String
  address         String?
  city            String?  @default("Forest Grove")
  state           String?  @default("OR")
  zip             String?
  purchasePrice   Decimal? @db.Decimal(12, 2)
  purchaseDate    DateTime? @db.Date
  currentValue    Decimal? @db.Decimal(12, 2)
  downPayment     Decimal? @db.Decimal(12, 2)
  closingCosts    Decimal? @db.Decimal(12, 2)
  rehabCosts      Decimal? @db.Decimal(12, 2)
  ownershipPercent Decimal @default(1) @db.Decimal(5, 4)
  notes           String?
  units           Unit[]
  loans           Loan[]
  expenses        Expense[]
  distributions   Distribution[]
  vendors         Vendor[]
  members         PropertyMember[]
  documents       Document[]
  recurring       RecurringExpense[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Application-level user record. Linked 1:1 to a Supabase auth.users row
// via authUserId. Holds role + per-property memberships.
model AppUser {
  id           String           @id @default(cuid())
  authUserId   String           @unique
  email        String           @unique
  firstName    String?
  lastName     String?
  role         String           @default("partner") // "admin" | "partner" | "manager"
  memberships  PropertyMember[]
  invitesSent  PartnerInvite[]  @relation("inviter")
  documents    Document[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model PropertyMember {
  id           String   @id @default(cuid())
  userId       String
  propertyId   String
  permissions  String   @default("read") // "read" | "manage"
  user         AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@unique([userId, propertyId])
  @@index([propertyId])
}

model RecurringExpense {
  id          String    @id @default(cuid())
  propertyId  String
  category    String
  amount      Decimal   @db.Decimal(12, 2)
  vendor      String?
  memo        String?
  // Day-of-month to apply (1-28 to avoid Feb edge cases).
  dayOfMonth  Int       @default(1)
  startDate   DateTime  @db.Date
  endDate     DateTime? @db.Date
  active      Boolean   @default(true)
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([propertyId])
}

model Document {
  id           String    @id @default(cuid())
  // Exactly one of these is set, depending on what the doc is attached to.
  propertyId   String?
  unitId       String?
  leaseId      String?
  name         String
  category     String    @default("Other") // "Lease" | "Insurance" | "Inspection" | "Photo" | "Receipt" | "Tax" | "Other"
  storagePath  String    // path inside the "documents" Supabase Storage bucket
  contentType  String?
  sizeBytes    Int?
  notes        String?
  uploadedById String?
  uploadedAt   DateTime  @default(now())

  property     Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit         Unit?     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  lease        Lease?    @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  uploadedBy   AppUser?  @relation(fields: [uploadedById], references: [id])

  @@index([propertyId])
  @@index([unitId])
  @@index([leaseId])
}

model PartnerInvite {
  id           String    @id @default(cuid())
  email        String
  inviterId    String
  propertyId   String?   // optional — auto-add member to this property on accept
  permissions  String    @default("read")
  role         String    @default("partner")
  token        String    @unique @default(cuid())
  createdAt    DateTime  @default(now())
  expiresAt    DateTime
  acceptedAt   DateTime?
  inviter      AppUser   @relation("inviter", fields: [inviterId], references: [id])

  @@index([email])
}

model Asset {
  id              String    @id @default(cuid())
  symbol          String
  name            String?
  kind            String    // "Stock", "Crypto", "Cash", "Retirement", "Fund", "Other"
  account         String?   // "Chase Brokerage", "401k", "Wallet", etc.
  quantity        Decimal   @db.Decimal(24, 8)
  costBasis       Decimal?  @db.Decimal(14, 2)  // total cost basis in USD
  avgCostPerShare Decimal?  @db.Decimal(14, 4)
  acquisitionDate DateTime? @db.Date
  manualPrice     Decimal?  @db.Decimal(14, 4)  // used if no live price source
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Distribution {
  id          String   @id @default(cuid())
  propertyId  String
  paidAt      DateTime @db.Date
  amount      Decimal  @db.Decimal(12, 2)
  kind        String   @default("Distribution") // "Distribution", "Refi Cash Out", "Sale Proceeds"
  memo        String?
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([propertyId, paidAt])
}

model Loan {
  id              String   @id @default(cuid())
  propertyId      String
  lender          String
  originalAmount  Decimal  @db.Decimal(12, 2)
  currentBalance  Decimal  @db.Decimal(12, 2)
  interestRate    Decimal  @db.Decimal(5, 3)
  termMonths      Int
  monthlyPayment  Decimal  @db.Decimal(10, 2)
  startDate       DateTime @db.Date
  maturityDate    DateTime? @db.Date
  loanType        String?  @default("Fixed")
  notes           String?
  property        Property @relation(fields: [propertyId], references: [id])
  payments        LoanPayment[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([propertyId])
}

model LoanPayment {
  id            String   @id @default(cuid())
  loanId        String
  paidAt        DateTime @db.Date
  totalAmount   Decimal  @db.Decimal(10, 2)
  principal     Decimal  @db.Decimal(10, 2)
  interest      Decimal  @db.Decimal(10, 2)
  escrow        Decimal? @db.Decimal(10, 2)
  memo          String?
  loan          Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@index([loanId, paidAt])
}

model Unit {
  id         String   @id @default(cuid())
  propertyId String?
  label      String   @unique
  bedrooms   Int
  bathrooms  Float
  sqft       Int?
  rent       Decimal  @db.Decimal(10, 2)
  rubs       Decimal  @default(0) @db.Decimal(10, 2)
  parking    Decimal  @default(0) @db.Decimal(10, 2)
  storage    Decimal  @default(0) @db.Decimal(10, 2)
  notes      String?
  property   Property? @relation(fields: [propertyId], references: [id])
  leases     Lease[]
  tickets    MaintenanceTicket[]
  documents  Document[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([propertyId])
}

model Tenant {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String?  @unique
  phone     String?
  notes     String?
  leases    Lease[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lease {
  id              String      @id @default(cuid())
  unitId          String
  tenantId        String
  startDate       DateTime    @db.Date
  endDate         DateTime    @db.Date
  monthlyRent     Decimal     @db.Decimal(10, 2)
  securityDeposit Decimal     @default(0) @db.Decimal(10, 2)
  status          LeaseStatus @default(ACTIVE)
  portalToken     String?     @unique @default(cuid())
  documentUrl     String?
  unit            Unit        @relation(fields: [unitId], references: [id])
  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  charges         Charge[]
  payments        Payment[]
  documents       Document[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([unitId])
  @@index([tenantId])
}

enum LeaseStatus {
  PENDING
  ACTIVE
  ENDED
  TERMINATED
}

model Charge {
  id        String     @id @default(cuid())
  leaseId   String
  type      ChargeType @default(RENT)
  amount    Decimal    @db.Decimal(10, 2)
  dueDate   DateTime   @db.Date
  memo      String?
  lease     Lease      @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@index([leaseId, dueDate])
}

enum ChargeType {
  RENT
  LATE_FEE
  UTILITY
  OTHER
}

model Payment {
  id        String        @id @default(cuid())
  leaseId   String
  amount    Decimal       @db.Decimal(10, 2)
  paidAt    DateTime      @db.Date
  method    PaymentMethod @default(ACH)
  reference String?
  memo      String?
  lease     Lease         @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@index([leaseId, paidAt])
}

enum PaymentMethod {
  ACH
  CARD
  CHECK
  CASH
  OTHER
}

model Vendor {
  id        String              @id @default(cuid())
  name      String
  trade     String?
  phone     String?
  email     String?
  notes     String?
  tickets   MaintenanceTicket[]
  properties Property[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
}

model MaintenanceTicket {
  id          String       @id @default(cuid())
  unitId      String?
  vendorId    String?
  title       String
  description String?
  status      TicketStatus @default(OPEN)
  priority    Priority     @default(NORMAL)
  cost        Decimal?     @db.Decimal(10, 2)
  openedAt    DateTime     @default(now())
  closedAt    DateTime?
  unit        Unit?        @relation(fields: [unitId], references: [id])
  vendor      Vendor?      @relation(fields: [vendorId], references: [id])

  @@index([status])
  @@index([unitId])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_VENDOR
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model Expense {
  id         String    @id @default(cuid())
  propertyId String?
  unitId     String?
  category   String
  amount     Decimal   @db.Decimal(10, 2)
  incurredAt DateTime  @db.Date
  vendor     String?
  memo       String?
  receiptUrl String?
  property   Property? @relation(fields: [propertyId], references: [id])
  createdAt  DateTime  @default(now())

  @@index([incurredAt])
  @@index([propertyId])
}
